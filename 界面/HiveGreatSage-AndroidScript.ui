<窗口
	宽度="600"
	高度="700"
	显示确认按钮="false"
	显示标题栏="true"
	标题="蜂巢·大圣"
	标签头高度="-2"
	配置文件="main.config"
	标签头背景="#ffffffff"
	标签头字体大小="16"
	标签头选中字体颜色="#ffff3377"
	标签头字体默认颜色="#ff3355ff">

	<!-- ═══════════════ 标签页1：登录 ═══════════════ -->
	<标签页
		标题="登录"
		背景="#ffffffff">

		<垂直布局 宽度="-1" 高度="-1" 边距="30,20,30,20" 间距="16">

			<!-- 标题 -->
			<文本框
				宽度="-1" 高度="-2"
				默认值="蜂巢·大圣 — 登录"
				文字大小="22"
				文字颜色="#ff333333"
				只读="true"
				边距="0,0,0,10"/>

			<!-- 账号 -->
			<文本框
				id="id_label_username"
				宽度="-1" 高度="-2"
				默认值="账号"
				文字大小="14"
				文字颜色="#ff666666"
				只读="true"/>
			<输入框
				id="id_username"
				宽度="-1" 高度="50"
				提示="请输入账号"
				文字大小="16"
				边距="0,0,0,0"/>

			<!-- 密码 -->
			<文本框
				id="id_label_password"
				宽度="-1" 高度="-2"
				默认值="密码"
				文字大小="14"
				文字颜色="#ff666666"
				只读="true"/>
			<输入框
				id="id_password"
				宽度="-1" 高度="50"
				提示="请输入密码"
				文字大小="16"
				密码="true"
				边距="0,0,0,0"/>

			<!-- 设备编号（仅展示用，非身份） -->
			<文本框
				id="id_label_alias"
				宽度="-1" 高度="-2"
				默认值="设备编号（展示用）"
				文字大小="14"
				文字颜色="#ff666666"
				只读="true"/>
			<输入框
				id="id_alias"
				宽度="-1" 高度="50"
				提示="选填，如 001"
				文字大小="16"
				边距="0,0,0,0"/>

			<!-- 随机延时勾选 -->
			<勾选框
				id="id_random_delay"
				宽度="-1" 高度="-2"
				默认值="false"
				文字="登录后随机延时（1~60s，防同步）"
				文字大小="14"
				文字颜色="#ff555555"/>

			<!-- 登录按钮 -->
			<按钮
				id="id_btn_login"
				宽度="-1" 高度="56"
				文字="登 录"
				文字大小="18"
				背景颜色="#ffff3377"
				文字颜色="#ffffffff"
				边距="0,10,0,0"
				点击="on_login_click"/>

			<!-- 状态提示 -->
			<文本框
				id="id_login_status"
				宽度="-1" 高度="-2"
				默认值=""
				文字大小="13"
				文字颜色="#ffcc0000"
				只读="true"/>

		</垂直布局>
	</标签页>

	<!-- ═══════════════ 标签页2：运行状态 ═══════════════ -->
	<标签页
		标题="运行"
		背景="#ffffffff">

		<垂直布局 宽度="-1" 高度="-1" 边距="30,20,30,20" 间距="12">

			<文本框
				宽度="-1" 高度="-2"
				默认值="运行状态"
				文字大小="20"
				文字颜色="#ff333333"
				只读="true"/>

			<!-- 当前状态（由 UIHelper.update_status 更新） -->
			<文本框
				id="id_status"
				宽度="-1" 高度="-2"
				默认值="待机中"
				文字大小="16"
				文字颜色="#ff555555"
				只读="true"/>

			<!-- 连接状态 -->
			<文本框
				id="id_conn_status"
				宽度="-1" 高度="-2"
				默认值="云端：未连接  |  中控：未连接"
				文字大小="13"
				文字颜色="#ff888888"
				只读="true"/>

		</垂直布局>
	</标签页>

	<!-- ═══════════════ 标签页3：设置 ═══════════════ -->
	<标签页
		标题="设置"
		背景="#ffffffff">

		<垂直布局 宽度="-1" 高度="-1" 边距="30,20,30,20" 间距="16">

			<文本框
				宽度="-1" 高度="-2"
				默认值="设置"
				文字大小="20"
				文字颜色="#ff333333"
				只读="true"/>

			<!-- PC 中控 IP -->
			<文本框
				宽度="-1" 高度="-2"
				默认值="PC 中控 IP"
				文字大小="14"
				文字颜色="#ff666666"
				只读="true"/>
			<输入框
				id="id_lan_ip"
				宽度="-1" 高度="50"
				提示="如 192.168.1.100"
				文字大小="16"/>

			<!-- 保存设置按钮 -->
			<按钮
				id="id_btn_save"
				宽度="-1" 高度="50"
				文字="保存设置"
				文字大小="16"
				背景颜色="#ff3355ff"
				文字颜色="#ffffffff"
				点击="on_save_click"/>

			<!-- 全局初始化（危险区） -->
			<文本框
				宽度="-1" 高度="-2"
				默认值="─────────── 危险操作 ───────────"
				文字大小="13"
				文字颜色="#ffcc0000"
				只读="true"
				边距="0,20,0,0"/>

			<按钮
				id="id_btn_global_init"
				宽度="-1" 高度="50"
				文字="全局初始化（清除游戏数据）"
				文字大小="15"
				背景颜色="#ffaa0000"
				文字颜色="#ffffffff"
				点击="on_global_init_click"/>

		</垂直布局>
	</标签页>

</窗口>
